class BusPeoples{
    public static void main(String[] args)
    {
        int[] arr={1,8,3,7,5,6};
        int n=arr.length;
        int ans=0,temp=0;
        int l=0;
        int bus=3;
        for(int r=0;r<n;r++)
        {
            temp+=arr[r];
            if(r-l==bus)
            {
                temp-=arr[l];
                l++;
            }if(r-l+1==bus)
            {
                ans=Math.max(ans,temp);
            }
        }
        System.out.println(ans);
    }
}
